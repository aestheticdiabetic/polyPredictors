# Polymarket Credentials (required for REAL mode)
POLY_PRIVATE_KEY=your_private_key_here
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_passphrase_here
POLY_FUNDER_ADDRESS=your_funder_address_here

# App Settings (optional overrides)
SIM_STARTING_BALANCE=200.0
MAX_BET_PCT=0.05
POLLING_INTERVAL_SECONDS=30
# How often the permanent resolution checker runs (seconds).
# Lower values catch the 0.05 exit threshold before prices snap to 0.0 at resolution.
RESOLUTION_CHECK_INTERVAL_SECONDS=60
MIN_MARKET_HOURS_TO_CLOSE=1.0

# Maximum price drift (in probability points) allowed between the whale's observed
# entry price and the current live price before we skip copying their bet.
# Example: whale_price=0.20, live_price=0.26 → drift=0.06 > 0.05 → SKIPPED.
# Set higher (e.g. 0.10) to be more permissive, lower (e.g. 0.02) to be stricter.
MAX_PRICE_DRIFT_PCT=0.05

# Ignore whale trades older than this many hours.  Stops historical trades
# (fetched when a whale is first added) from being evaluated against closed markets.
# Default 24h means only same-day trades are ever considered.
MAX_TRADE_AGE_HOURS=24.0

# Minimum USDC trading volume a trader must have to appear in the Discover Whales modal.
# The Polymarket API does not expose a prediction count, so volume is used as a proxy.
# Default $1,000,000 roughly corresponds to very high-activity traders.
# Lower to $100,000 to see more results; raise to $5,000,000 for top-tier only.
MIN_WHALE_VOLUME_USDC=1000000

# Optional: route app traffic through a VPN HTTP proxy (e.g. gluetun on port 8888)
# PROXY_URL=http://localhost:8888
